{
  "contract_id": "CONC-001",
  "name": "Concurrent Insert Count Consistency",
  "family": "CONC",
  "type": "universal",
  "statement": "After N concurrent insert operations, count_entities must equal total inserted entities",
  "rationale": "Concurrent write operations must not corrupt each other's data; final count must reflect all successful inserts",
  "scope": {
    "databases": ["all"],
    "operations": ["insert", "count_entities"],
    "conditions": ["concurrent_execution"]
  },
  "preconditions": [
    "collection_exists",
    "multiple_writer_threads",
    "deterministic_ids_or_auto_id_handled"
  ],
  "postconditions": [
    "count_entities == sum(insert_counts_per_thread)",
    "no_data_corruption_observed"
  ],
  "invariants": [
    "Total entity count is consistent with insert operations",
    "No phantom or duplicated entities from race conditions"
  ],
  "violation_criteria": {
    "condition": "count_entities != expected_total_after_concurrent_inserts",
    "severity": "high",
    "cc_classification": "Type-4"
  },
  "test_generation": {
    "strategy": "concurrent",
    "parameters": {
      "n_threads": [2, 4, 8],
      "vectors_per_thread": [50, 100, 200],
      "dim": [32, 128, 384]
    },
    "cases": [
      {
        "name": "Basic concurrent insert",
        "n_threads": 3,
        "vectors_per_thread": 50,
        "expected_total": 150
      },
      {
        "name": "High contention insert",
        "n_threads": 8,
        "vectors_per_thread": 100,
        "expected_total": 800
      }
    ]
  },
  "oracle": {
    "check": "count_entities == expected_total",
    "verification": "assert actual_count == expected_total",
    "classification": {
      "violation": "BUG (concurrency_violation)",
      "compliant": "PASS"
    }
  },
  "metadata": {
    "confidence": "high",
    "dependencies": [],
    "test_complexity": "medium",
    "version": "1.0",
    "sbmf_reference": "CONC-001"
  }
}
